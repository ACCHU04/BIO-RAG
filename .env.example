# ── LLM (Gemini) ─────────────────────────────────────
GOOGLE_API_KEY=your-google-gemini-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# ── Web Search ────────────────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-key-here

# ── Biomedical APIs (no key needed, but set email) ────
ENTREZ_EMAIL=your-email@university.edu
ENTREZ_API_KEY=your-ncbi-api-key-here   # optional but increases rate limit

# ── Vector Store ──────────────────────────────────────
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=biomedical_docs

# ── Embedding Model ───────────────────────────────────
EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO  # biomedical-specific embeddings

# ── Agent Settings ────────────────────────────────────
MAX_ITERATIONS=10
MAX_DOCUMENTS_PER_QUERY=5
RELEVANCE_THRESHOLD=0.75
SELF_CORRECTION_ATTEMPTS=3

# ── FastAPI ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8742
DEBUG=true

# ── OpenRouter (Incognito Mode — optional) ────────────
OPENROUTER_API_KEY=your-openrouter-api-key-here  # get at https://openrouter.ai/keys

# ── Kaggle (For CORD-19 Ingestion) ────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
